{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKERFILE"
    },
    "deploy": {
        "numReplicas": 1,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    },
    "volumes": {
        "data": {
            "mountPath": "/var/www/public/uploads"
        },
        "storage": {
            "mountPath": "/var/www/storage"
        }
    }
}
